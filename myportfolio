      border-radius: 4px;
      display: grid;
      grid-template-columns: 60px 1fr auto;
      align-items: center;
      gap: 24px;
      padding: 22px 24px;
      transition: border-color 0.2s;
    }

    .p-card:hover {
      border-color: #ff6600;
    }

    .p-number {
