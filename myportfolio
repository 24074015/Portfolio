      font-weight: bold;
      color: #ffffff;
    }

    header .site-name span {
      color: #ff6600;
    }

    header nav ul {
      list-style: none;
      display: flex;
      gap: 20px;
    }

    header nav ul li a {
      color: #cccccc;
      text-decoration: none;
      font-size: 13px;
    }

    header nav ul li a:hover {
      color: #ff6600;
    }

    /* ---------- HERO ---------- */
    .hero {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 88vh;
    }

    /* Left side - dark */
    .hero-left {
      background-color: #111111;
      padding: 70px 50px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      border-right: 3px solid #ff6600;
    }

    .hero-left .greeting {
      font-size: 13px;
      color: #ff6600;
      text-transform: uppercase;
      letter-spacing: 3px;
      margin-bottom: 14px;
    }

    .hero-left h1 {
      font-size: 42px;
      color: #ffffff;
      line-height: 1.15;
      margin-bottom: 6px;
    }

    .hero-left h1 .orange {
      color: #ff6600;
    }

    .hero-left .role {
      font-size: 15px;
      color: #888888;
      margin-bottom: 6px;
    }

    .hero-left .uni {
      font-size: 13px;
      color: #555555;
      margin-bottom: 35px;
    }

    .hero-left .about-short {
      font-size: 14px;
      color: #999999;
      line-height: 1.8;
      max-width: 400px;
      margin-bottom: 35px;
      border-left: 3px solid #ff6600;
      padding-left: 14px;
    }

    .hero-btns {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .btn {
      padding: 10px 22px;
      font-size: 13px;
      font-weight: bold;
      border: none;
      border-radius: 3px;
      cursor: pointer;
      text-decoration: none;
      display: inline-block;
      font-family: Arial, sans-serif;
    }

    .btn-fill {
      background-color: #ff6600;
      color: #000;
    }

    .btn-fill:hover {
      background-color: #cc5200;
    }

    .btn-ghost {
      background-color: transparent;
      color: #ff6600;
      border: 1px solid #ff6600;
    }

    .btn-ghost:hover {
      background-color: #ff6600;
      color: #000;
    }

    /* Right side */
    .hero-right {
      background-color: #0a0a0a;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px;
    }

    .id-card {
      background-color: #141414;
      border: 1px solid #2a2a2a;
      border-radius: 8px;
