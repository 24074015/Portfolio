      font-size: 12px;
      text-transform: uppercase;
      color: #ff6600;
      letter-spacing: 0.07em;
      margin-bottom: 8px;
    }

    .goal-block p {
      font-size: 13px;
      color: #888;
      line-height: 1.8;
    }

    /* Info list */
