      .hero-left {
        padding: 50px 24px;
        border-right: none;
        border-bottom: 3px solid #ff6600;
      }

      .hero-right {
        padding: 30px 24px;
      }

      #about {
        grid-template-columns: 1fr;
        padding: 50px 24px;
        gap: 36px;
      }

      .skills-boxes {
        grid-template-columns: 1fr 1fr;
      }

      #skills, #projects, #contact {
        padding: 50px 24px;
      }

      .p-card {
        grid-template-columns: 1fr;
        gap: 10px;
      }

      .p-number {
        font-size: 20px;
      }

      .contact-grid {
        grid-template-columns: 1fr;
        gap: 30px;
      }

      header {
        flex-direction: column;
        gap: 12px;
      }

      footer {
        flex-direction: column;
        text-align: center;
        padding: 20px;
      }
    }

  </style>
