    .id-card-top {
      background-color: #ff6600;
      padding: 14px 18px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .id-card-top .card-logo {
      font-size: 13px;
      font-weight: bold;
      color: #000;
      letter-spacing: 1px;
    }

    .id-card-body {
